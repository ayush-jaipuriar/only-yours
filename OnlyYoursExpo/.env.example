# Base URL for the Only Yours backend API (no trailing slash)
# For physical phone testing on same Wi-Fi, use your laptop LAN IP:
# EXPO_PUBLIC_API_URL=http://192.168.x.y:8080
# If you also create `.env.local`, keep the same value there too because Expo loads
# `.env.local` before `.env` and it will override this file.
EXPO_PUBLIC_API_URL=http://localhost:8080
